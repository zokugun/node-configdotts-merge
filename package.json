{
	"name": "@zokugun/configdotts-merge",
	"description": "Merge config.ts files while preserving comments",
	"version": "0.2.0",
	"author": {
		"name": "Baptiste Augrain",
		"email": "daiyam@zokugun.org"
	},
	"license": "MIT",
	"homepage": "https://github.com/zokugun/node-configdotts-merge",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/zokugun/node-configdotts-merge.git"
	},
	"bugs": {
		"url": "https://github.com/zokugun/node-configdotts-merge/discussions/categories/issue-triage"
	},
	"exports": {
		".": {
			"import": "./lib/esm/index.mjs",
			"require": "./lib/cjs/index.cjs"
		}
	},
	"main": "lib/cjs/index.cjs",
	"module": "lib/esm/index.mjs",
	"typesVersions": {
		"*": {
			".": [
				"./lib/cjs/index.d.cts"
			]
		}
	},
	"scripts": {
		"audit:fix": "npm audit fix --min-release-age=0",
		"build": "npm run clean && npm run build:lib",
		"build:lib": "tsc-leda generate",
		"build:package": "tsc-leda update-package",
		"ci:lint": "zizmor .",
		"ci:lint:fix": "zizmor . --fix=all",
		"clean": "rimraf lib; rimraf .src",
		"compile:src": "tsc -p src",
		"lint": "xo",
		"lint:all": "fixpack && npm audit && npm run ci:lint && npm run lint",
		"lint:fix": "xo --fix",
		"prepack": "npm run build",
		"prepare": "husky; fixpack || true",
		"release": "release-it",
		"test": "tsc -p test && mocha",
		"test:dev": "mocha",
		"test:watch": "tsc-watch -p src -p test --onSuccess 'mocha'",
		"update:artifacts": "artifact update",
		"update:ci": "PINACT_MIN_AGE=7 pinact run",
		"update:deps": "taze",
		"watch:build": "tsc-watch -p src --onSuccess 'npm run build'",
		"watch:src": "tsc-watch -p src",
		"watch:test": "tsc-watch -p test"
	},
	"dependencies": {},
	"devDependencies": {
		"@commitlint/cli": "19.8.1",
		"@commitlint/config-conventional": "19.8.1",
		"@types/chai": "4.3.16",
		"@types/fs-extra": "11.0.4",
		"@types/klaw-sync": "6.0.5",
		"@types/mocha": "10.0.10",
		"@types/node": "20.19.39",
		"@zokugun/tsc-leda": "0.3.2",
		"chai": "4.5.0",
		"chai-as-promised": "7.1.2",
		"eslint-plugin-chai-friendly": "1.2.0",
		"fixpack": "4.0.0",
		"fs-extra": "11.3.4",
		"globby": "14.1.0",
		"husky": "9.1.7",
		"klaw-sync": "7.0.0",
		"lint-staged": "16.4.0",
		"mocha": "11.7.5",
		"release-it": "20.0.0-1",
		"source-map-support": "0.5.21",
		"taze": "19.11.0",
		"tsc-watch": "7.2.0",
		"typescript": "5.9.3",
		"xo": "0.60.0",
		"yaml": "1.10.3"
	},
	"peerDependencies": {
		"typescript": ">=5.0.0"
	},
	"overrides": {
		"mocha": {
			"diff": "8.0.3",
			"serialize-javascript": "7.0.5"
		}
	},
	"keywords": []
}
